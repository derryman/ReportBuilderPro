# Local testing only – copy to .env.local (do not commit)
# When .env.local exists, the server uses these instead of .env so you can log in against local MongoDB.
# Keep your main .env for Azure/production; use .env.local only on your machine.

MONGO_URI=mongodb://localhost:27017/
MONGO_DB=ReportBuilderPro

# Optional: uncomment if you want NLP when running run_all_local.bat
# NLP_SERVICE_URL=http://localhost:8000

# Optional: online writing review before PDF export
# Set WRITING_REVIEW_ENABLED=1 and point WRITING_REVIEW_URL to a LanguageTool-compatible /v2/check endpoint.
# Example public endpoint for testing only: https://api.languagetool.org/v2/check
# WRITING_REVIEW_ENABLED=1
# WRITING_REVIEW_URL=https://api.languagetool.org/v2/check
# WRITING_REVIEW_LANGUAGE=en-GB
# WRITING_REVIEW_MAX_ISSUES=12
# WRITING_REVIEW_USERNAME=
# WRITING_REVIEW_API_KEY=
